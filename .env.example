# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/shopify_reviews?retryWrites=true&w=majority

# Port (optional - Vercel ignores this, only needed for local dev)
PORT=5000

# Your Shopify store domain (for CORS whitelist)
# Example: mystore.myshopify.com  OR  www.mystore.com
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
